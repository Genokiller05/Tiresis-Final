-- ==========================================
-- TIRESIS / SIVIS - Esquema 3FN para Supabase
-- ==========================================

-- Habilita UUIDs (en Supabase suele estar habilitado, pero se deja por claridad)
create extension if not exists pgcrypto;

-- =========================
-- A) Núcleo de organización
-- =========================

create table if not exists public.sites (
  id uuid primary key default gen_random_uuid(),
  name text not null,
  address text,
  is_active boolean not null default true,
  created_at timestamptz not null default now()
);

create table if not exists public.roles (
  id int generated always as identity primary key,
  code text not null unique, -- admin, supervisor, guard, resident
  name text not null
);

create table if not exists public.profiles (
  id uuid primary key, -- FK a auth.users(id) (se suele poblar con trigger handle_new_user)
  full_name text not null,
  document_id text unique,
  phone text,
  created_at timestamptz not null default now()
);

create table if not exists public.site_memberships (
  site_id uuid not null references public.sites(id) on delete cascade,
  user_id uuid not null references public.profiles(id) on delete cascade,
  role_id int not null references public.roles(id),
  is_active boolean not null default true,
  created_at timestamptz not null default now(),
  primary key (site_id, user_id)
);

create index if not exists idx_site_memberships_role on public.site_memberships(role_id);
create index if not exists idx_site_memberships_user on public.site_memberships(user_id);

-- =========================
-- B) Dispositivos (opcional)
-- =========================
create table if not exists public.devices (
  id uuid primary key default gen_random_uuid(),
  user_id uuid not null references public.profiles(id) on delete cascade,
  device_type text not null,
  push_token text,
  last_seen_at timestamptz,
  created_at timestamptz not null default now()
);

create index if not exists idx_devices_user on public.devices(user_id);

-- =========================
-- C) Turnos / Operación
-- =========================

create table if not exists public.assignment_statuses (
  id int generated always as identity primary key,
  code text not null unique, -- assigned, on_duty, finished
  name text not null
);

create table if not exists public.shifts (
  id uuid primary key default gen_random_uuid(),
  site_id uuid not null references public.sites(id) on delete cascade,
  start_at timestamptz not null,
  end_at timestamptz not null,
  created_by uuid not null references public.profiles(id),
  created_at timestamptz not null default now(),
  constraint chk_shift_time check (end_at > start_at)
);

create index if not exists idx_shifts_site on public.shifts(site_id);
create index if not exists idx_shifts_time on public.shifts(start_at, end_at);

create table if not exists public.shift_assignments (
  shift_id uuid not null references public.shifts(id) on delete cascade,
  guard_id uuid not null references public.profiles(id) on delete cascade,
  status_id int not null references public.assignment_statuses(id),
  assigned_at timestamptz not null default now(),
  primary key (shift_id, guard_id)
);

create index if not exists idx_shift_assignments_guard on public.shift_assignments(guard_id);

-- =========================
-- D) Ubicaciones (catálogo)
-- =========================
create table if not exists public.locations (
  id uuid primary key default gen_random_uuid(),
  site_id uuid not null references public.sites(id) on delete cascade,
  name text not null,
  description text,
  is_active boolean not null default true,
  created_at timestamptz not null default now(),
  unique (site_id, name)
);

create index if not exists idx_locations_site on public.locations(site_id);

-- =========================
-- E) Catálogos de estados y tipos
-- =========================

-- Prioridad / Severidad (se reutiliza en reportes y alertas)
create table if not exists public.priorities (
  id int generated always as identity primary key,
  code text not null unique, -- low, medium, high, critical
  name text not null
);

create table if not exists public.report_types (
  id int generated always as identity primary key,
  code text not null unique, -- incident, novelty, patrol, received_alert
  name text not null
);

create table if not exists public.report_statuses (
  id int generated always as identity primary key,
  code text not null unique, -- pending, in_review, closed
  name text not null
);

create table if not exists public.resident_notice_types (
  id int generated always as identity primary key,
  code text not null unique, -- suspicious_person, noise, other
  name text not null
);

create table if not exists public.resident_notice_statuses (
  id int generated always as identity primary key,
  code text not null unique, -- pending, in_review, closed
  name text not null
);

create table if not exists public.alert_sources (
  id int generated always as identity primary key,
  code text not null unique, -- ai, manual, panic, resident
  name text not null
);

create table if not exists public.alert_types (
  id int generated always as identity primary key,
  code text not null unique, -- intrusion, tripwire_cross, roi_intrusion, panic, other
  name text not null
);

create table if not exists public.alert_statuses (
  id int generated always as identity primary key,
  code text not null unique, -- pending, in_review, resolved, false_alarm
  name text not null
);

-- =========================
-- F) Reportes (Guardia)
-- =========================
create table if not exists public.reports (
  id uuid primary key default gen_random_uuid(),
  site_id uuid not null references public.sites(id) on delete cascade,
  shift_id uuid references public.shifts(id) on delete set null,
  created_by_guard_id uuid not null references public.profiles(id),
  report_type_id int not null references public.report_types(id),
  status_id int not null references public.report_statuses(id),
  priority_id int not null references public.priorities(id),
  location_id uuid references public.locations(id) on delete set null,
  gps_lat numeric(10,7),
  gps_lng numeric(10,7),
  short_description text not null,
  created_at timestamptz not null default now(),
  closed_at timestamptz,
  constraint chk_report_gps check (
    (gps_lat is null and gps_lng is null) or (gps_lat is not null and gps_lng is not null)
  )
);

create index if not exists idx_reports_site on public.reports(site_id);
create index if not exists idx_reports_status on public.reports(status_id);
create index if not exists idx_reports_guard on public.reports(created_by_guard_id);
create index if not exists idx_reports_created_at on public.reports(created_at);

-- Cierre/Resolución de reporte separado (3FN + trazabilidad)
create table if not exists public.report_closures (
  report_id uuid primary key references public.reports(id) on delete cascade,
  closed_by_user_id uuid not null references public.profiles(id),
  resolution_notes text not null,
  closed_at timestamptz not null default now()
);

-- =========================
-- G) Avisos (Residente)
-- =========================
create table if not exists public.resident_notices (
  id uuid primary key default gen_random_uuid(),
  site_id uuid not null references public.sites(id) on delete cascade,
  resident_id uuid not null references public.profiles(id),
  notice_type_id int not null references public.resident_notice_types(id),
  status_id int not null references public.resident_notice_statuses(id),
  location_id uuid references public.locations(id) on delete set null,
  gps_lat numeric(10,7),
  gps_lng numeric(10,7),
  description text not null,
  created_at timestamptz not null default now(),
  closed_at timestamptz,
  constraint chk_notice_gps check (
    (gps_lat is null and gps_lng is null) or (gps_lat is not null and gps_lng is not null)
  )
);

create index if not exists idx_notices_site on public.resident_notices(site_id);
create index if not exists idx_notices_status on public.resident_notices(status_id);
create index if not exists idx_notices_resident on public.resident_notices(resident_id);
create index if not exists idx_notices_created_at on public.resident_notices(created_at);

-- =========================
-- H) Cámaras / Zonas IA
-- =========================
create table if not exists public.cameras (
  id uuid primary key default gen_random_uuid(),
  site_id uuid not null references public.sites(id) on delete cascade,
  name text not null,
  rtsp_url text not null,
  location_description text,
  is_active boolean not null default true,
  created_at timestamptz not null default now(),
  unique (site_id, name)
);

create index if not exists idx_cameras_site on public.cameras(site_id);

create table if not exists public.zone_types (
  id int generated always as identity primary key,
  code text not null unique, -- tripwire, roi
  name text not null
);

create table if not exists public.security_zones (
  id uuid primary key default gen_random_uuid(),
  camera_id uuid not null references public.cameras(id) on delete cascade,
  name text not null,
  zone_type_id int not null references public.zone_types(id),
  is_active boolean not null default true,
  created_at timestamptz not null default now(),
  unique (camera_id, name)
);

create index if not exists idx_zones_camera on public.security_zones(camera_id);

-- Coordenadas normalizadas (sin JSON) -> 3FN estricta
create table if not exists public.zone_coordinates (
  id uuid primary key default gen_random_uuid(),
  zone_id uuid not null references public.security_zones(id) on delete cascade,
  point_order int not null,
  x int not null,
  y int not null,
  unique (zone_id, point_order)
);

create index if not exists idx_zone_coordinates_zone on public.zone_coordinates(zone_id);

-- Reglas normalizadas
create table if not exists public.zone_rules (
  zone_id uuid primary key references public.security_zones(id) on delete cascade,
  direction text not null default 'both', -- both, inbound, outbound
  sensitivity numeric(3,2) not null default 0.80,
  min_dwell_ms int,
  enabled boolean not null default true,
  constraint chk_zone_direction check (direction in ('both','inbound','outbound')),
  constraint chk_zone_sensitivity check (sensitivity >= 0 and sensitivity <= 1)
);

create table if not exists public.object_classes (
  id int generated always as identity primary key,
  code text not null unique, -- person, car, etc.
  name text not null
);

create table if not exists public.zone_rule_objects (
  zone_id uuid not null references public.security_zones(id) on delete cascade,
  object_class_id int not null references public.object_classes(id) on delete restrict,
  primary key (zone_id, object_class_id)
);

-- =========================
-- I) Alertas (IA + Manual + Pánico + Residente)
-- =========================
create table if not exists public.alerts (
  id uuid primary key default gen_random_uuid(),
  site_id uuid not null references public.sites(id) on delete cascade,
  source_id int not null references public.alert_sources(id),
  alert_type_id int not null references public.alert_types(id),
  severity_id int not null references public.priorities(id), -- reutiliza prioridades como severidad
  status_id int not null references public.alert_statuses(id),
  camera_id uuid references public.cameras(id) on delete set null,
  zone_id uuid references public.security_zones(id) on delete set null,
  linked_report_id uuid references public.reports(id) on delete set null,
  linked_notice_id uuid references public.resident_notices(id) on delete set null,
  description text not null,
  created_at timestamptz not null default now()
);

create index if not exists idx_alerts_site on public.alerts(site_id);
create index if not exists idx_alerts_status on public.alerts(status_id);
create index if not exists idx_alerts_severity on public.alerts(severity_id);
create index if not exists idx_alerts_created_at on public.alerts(created_at);
create index if not exists idx_alerts_camera on public.alerts(camera_id);
create index if not exists idx_alerts_zone on public.alerts(zone_id);

-- Resolución separada (3FN + trazabilidad)
create table if not exists public.alert_resolutions (
  alert_id uuid primary key references public.alerts(id) on delete cascade,
  resolved_by_user_id uuid not null references public.profiles(id),
  resolution_notes text not null,
  resolved_at timestamptz not null default now()
);

-- Asignación con historial (recomendado)
create table if not exists public.alert_assignments (
  id uuid primary key default gen_random_uuid(),
  alert_id uuid not null references public.alerts(id) on delete cascade,
  assigned_to_user_id uuid not null references public.profiles(id),
  assigned_by_user_id uuid not null references public.profiles(id),
  assigned_at timestamptz not null default now(),
  is_active boolean not null default true,
  unassigned_at timestamptz
);

create index if not exists idx_alert_assignments_alert on public.alert_assignments(alert_id);
create index if not exists idx_alert_assignments_to on public.alert_assignments(assigned_to_user_id);

-- =========================
-- J) Evidencias (unificadas)
-- =========================
create table if not exists public.evidence_types (
  id int generated always as identity primary key,
  code text not null unique, -- photo, snapshot, clip, file
  name text not null
);

create table if not exists public.evidences (
  id uuid primary key default gen_random_uuid(),
  evidence_type_id int not null references public.evidence_types(id),
  storage_path text not null, -- ruta privada en Supabase Storage
